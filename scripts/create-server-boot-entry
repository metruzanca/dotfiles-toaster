#!/usr/bin/env bash
#
# Creates a "server mode" BLS boot entry for the current ostree deployment.
# Server mode boots into multi-user.target (no KDE/GUI).
#
# Safe to run multiple times — cleans up stale entries and recreates as needed.
#

set -euo pipefail

BLS_DIR="/boot/loader/entries"
SERVER_SUFFIX="-server"

latest_desktop=""
latest_version=""

# Find the latest (highest version) non-server BLS entry
for entry in "$BLS_DIR"/ostree-*.conf; do
    [[ -f "$entry" ]] || continue
    [[ "$entry" == *"$SERVER_SUFFIX.conf" ]] && continue

    ver=$(awk '/^version /{print $2}' "$entry")
    if [[ -z "$latest_version" || "$ver" -gt "$latest_version" ]]; then
        latest_version="$ver"
        latest_desktop="$entry"
    fi
done

if [[ -z "$latest_desktop" ]]; then
    echo "No ostree BLS entries found in $BLS_DIR" >&2
    exit 1
fi

echo "Latest desktop entry: $latest_desktop (version $latest_version)"

# Create server entry filename
server_file="${latest_desktop%.conf}${SERVER_SUFFIX}.conf"

# Skip if server entry already exists and points to the same kernel
if [[ -f "$server_file" ]]; then
    existing_linux=$(awk '/^linux /{print $2}' "$server_file")
    new_linux=$(awk '/^linux /{print $2}' "$latest_desktop")
    if [[ "$existing_linux" == "$new_linux" ]]; then
        echo "Server entry already up to date: $server_file"
        exit 0
    fi
    echo "Server entry exists but kernel differs, recreating..."
fi

# Build the server entry
{
    # Title: replace "Aurora" with "Aurora Server"
    awk '/^title /{sub(/^title /, ""); print "title Aurora Server (" $0 ")"; next} {print}' "$latest_desktop"
    # Append systemd.unit=multi-user.target to options line
    awk '/^options /{print $0 " systemd.unit=multi-user.target"; next} {print}' "$latest_desktop" | tail -n +2
} > "$server_file"

echo "Created server entry: $server_file"

# Clean up orphaned server entries (no matching desktop entry for the same version)
for stale in "$BLS_DIR"/ostree-*"$SERVER_SUFFIX.conf"; do
    [[ -f "$stale" ]] || continue
    base="${stale%$SERVER_SUFFIX.conf}"
    if [[ ! -f "$base" ]]; then
        echo "Removing orphaned server entry: $stale"
        rm "$stale"
    fi
done
